<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{traceId},%X{spanId}] - %msg%n</Property>
        <Property name="APP_NAME">discovery-server</Property>
    </Properties>

    <Appenders>
        <SpringProfile name="dev">
            <Console name="Console" target="SYSTEM_OUT">
                <PatternLayout pattern="${LOG_PATTERN}"/>
            </Console>
            <RollingFile name="File"
                         fileName="logs/${APP_NAME}.log"
                         filePattern="logs/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
                <PatternLayout pattern="${LOG_PATTERN}"/>
                <Policies>
                    <SizeBasedTriggeringPolicy size="10MB"/>
                    <TimeBasedTriggeringPolicy interval="1"/>
                </Policies>
                <DefaultRolloverStrategy max="30"/>
            </RollingFile>
        </SpringProfile>

        <SpringProfile name="prod,docker">
            <Console name="Console" target="SYSTEM_OUT">
                <JsonTemplateLayout
                        eventTemplateUri="classpath:log4j2-json-template.json"
                        nullEventTemplateFieldHandling="EXCLUDE">
                    <EventTemplateAdditionalField key="service" value="${APP_NAME}"/>
                </JsonTemplateLayout>
            </Console>
            <RollingFile name="File"
                         fileName="logs/${APP_NAME}.log"
                         filePattern="logs/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
                <JsonTemplateLayout
                        eventTemplateUri="classpath:log4j2-json-template.json"
                        nullEventTemplateFieldHandling="EXCLUDE">
                    <EventTemplateAdditionalField key="service" value="${APP_NAME}"/>
                </JsonTemplateLayout>
                <Policies>
                    <SizeBasedTriggeringPolicy size="10MB"/>
                    <TimeBasedTriggeringPolicy interval="1"/>
                </Policies>
                <DefaultRolloverStrategy max="30"/>
            </RollingFile>
        </SpringProfile>
    </Appenders>

    <Loggers>
        <Logger name="com.ticketapp" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>
        <Logger name="org.springframework" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- Eureka heartbeat loglarini susturuyoruz - cok gurultulu -->
        <Logger name="com.netflix.eureka" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="com.netflix.discovery" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>
