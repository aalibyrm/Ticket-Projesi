        <bpmndi:BPMNLabel><dc:Bounds x="906" y="315" width="70" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SLA BREACH TASK -->
      <bpmndi:BPMNShape id="Shape_SLA_Breach" bpmnElement="Task_SLA_Breach">
        <dc:Bounds x="1000" y="370" width="150" height="80" />
      </bpmndi:BPMNShape>

      <!-- SLA BREACH END -->
      <bpmndi:BPMNShape id="Shape_End_SLA_Breach" bpmnElement="End_SLA_Breach">
        <dc:Bounds x="1068" y="500" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1043" y="543" width="88" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ACTION GATEWAY -->
      <bpmndi:BPMNShape id="Shape_Gateway_AgentAction" bpmnElement="Gateway_AgentAction" isMarkerVisible="true">
        <dc:Bounds x="1063" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1046" y="195" width="84" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- SET PENDING -->
      <bpmndi:BPMNShape id="Shape_SetPending" bpmnElement="Task_SetPending">
