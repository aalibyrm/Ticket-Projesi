      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Approved_SetResolved" bpmnElement="Flow_Approved_SetResolved">
        <di:waypoint x="1461" y="130" /><di:waypoint x="1523" y="130" />
      </bpmndi:BPMNEdge>
      <!-- Loop: CustomerRejected → SetInProgress -->
      <bpmndi:BPMNEdge id="Edge_CustomerRejected_SetInProgress" bpmnElement="Flow_CustomerRejected_SetInProgress">
        <di:waypoint x="1443" y="398" /><di:waypoint x="1443" y="810" /><di:waypoint x="723" y="810" /><di:waypoint x="723" y="290" /><di:waypoint x="638" y="290" />
