      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SLA_Breach" bpmnElement="Flow_SLA_Breach">
        <di:waypoint x="970" y="308" /><di:waypoint x="970" y="340" /><di:waypoint x="1075" y="340" /><di:waypoint x="1075" y="370" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_SLA_Breach_End" bpmnElement="Flow_SLA_Breach_End">
        <di:waypoint x="1086" y="450" /><di:waypoint x="1086" y="500" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Action_RequestInfo" bpmnElement="Flow_Action_RequestInfo">
        <di:waypoint x="1088" y="275" /><di:waypoint x="1088" y="580" />
        <bpmndi:BPMNLabel><dc:Bounds x="1095" y="420" width="79" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Pending_WaitMsg" bpmnElement="Flow_Pending_WaitMsg">
        <di:waypoint x="1123" y="660" /><di:waypoint x="1123" y="720" />
      </bpmndi:BPMNEdge>
      <!-- Loop: CustomerInfo → SetInProgress -->
      <bpmndi:BPMNEdge id="Edge_CustomerInfo_SetInProgress" bpmnElement="Flow_CustomerInfo_SetInProgress">
        <di:waypoint x="1105" y="738" /><di:waypoint x="620" y="738" /><di:waypoint x="620" y="290" /><di:waypoint x="638" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Action_SendSolution" bpmnElement="Flow_Action_SendSolution">
        <di:waypoint x="1113" y="250" /><di:waypoint x="1183" y="250" />
        <bpmndi:BPMNLabel><dc:Bounds x="1123" y="228" width="69" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Waiting_EventGateway" bpmnElement="Flow_Waiting_EventGateway">
        <di:waypoint x="1353" y="250" /><di:waypoint x="1418" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Customer_Approved" bpmnElement="Flow_Customer_Approved">
