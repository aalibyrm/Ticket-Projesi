<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  id="Definitions_TicketManagement"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.19.0"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.4.0">

  <!-- =====================================================
       MESAJ TANIMLARI
       Spring Boot tarafı bu mesajları ticketId ile korelatif
       olarak Zeebe'ye gönderir.
       ===================================================== -->

  <!-- PENDING_CUSTOMER_INPUT: Müşteri ek bilgi sağladı -->
  <!-- ticketAssigned: Agent veya Team Leader atama yaptığında Spring Boot bu mesajı gönderir -->
  <bpmn:message id="Message_TicketAssigned" name="ticketAssigned">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=ticketId" />
    </bpmn:extensionElements>
  </bpmn:message>

  <bpmn:message id="Message_CustomerInfo" name="customerInfoProvided">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=ticketId" />
    </bpmn:extensionElements>
  </bpmn:message>

  <!-- WAITING_FOR_CUSTOMER: Müşteri çözümü onayladı -->
  <bpmn:message id="Message_CustomerApprove" name="customerApproved">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=ticketId" />
    </bpmn:extensionElements>
  </bpmn:message>

  <!-- WAITING_FOR_CUSTOMER: Müşteri çözümü reddetti → IN_PROGRESS -->
  <bpmn:message id="Message_CustomerReject" name="customerRejected">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=ticketId" />
    </bpmn:extensionElements>
  </bpmn:message>

  <!-- RESOLVED: Müşteri ticketı açıkça kapattı (onayladı) -->
  <bpmn:message id="Message_CustomerExplicitClose" name="customerExplicitClose">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=ticketId" />
    </bpmn:extensionElements>
  </bpmn:message>

<!-- Agent çözüm gönderdi → Task_WorkOnTicket'ı kes -->
<bpmn:message id="Message_AgentSendSolution" name="agentSendSolution">
  <bpmn:extensionElements>
    <zeebe:subscription correlationKey="=ticketId" />
  </bpmn:extensionElements>
</bpmn:message>

  <!-- =====================================================
       SÜREÇ
       process variables:
         ticketId          : String  – benzersiz ticket kimliği
         priority          : String  – LOW | MEDIUM | HIGH
         assignedAgent     : String  – atanan agent kullanıcı adı
         assignedTeam      : String  – atanan ekip adı
         candidateGroups   : String  – "agents,teamLeaders"
         agentAction       : String  – REQUEST_INFO | SEND_SOLUTION
         solutionNote      : String  – çözüm açıklaması
         slaRemainingDuration : ISO-8601 Duration (ör. PT4H)
         slaWarningDuration   : ISO-8601 Duration (ör. PT3H30M)
         slaPaused         : Boolean
         slaPausedAt       : String  – ISO datetime
   ===================================================== -->

  <bpmn:process id="Process_TicketManagement"
                name="Ticket Yönetim Süreci"
                isExecutable="true">

    <!-- ───────────────────────────────────────────────
         BAŞLANGIÇ
    ─────────────────────────────────────────────────── -->
    <bpmn:startEvent id="StartEvent_TicketCreated"
                     name="Müşteri&#10;Ticket Açar">
      <bpmn:outgoing>Flow_Start_SetNew</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ───────────────────────────────────────────────
         DURUM: NEW
         Worker type: ticket.state.setNew
         - DB'de ticket'ı NEW olarak kaydet
         - priority'e göre slaRemainingDuration ve
           slaWarningDuration hesapla ve process
           variable olarak set et
    ─────────────────────────────────────────────────── -->
    <bpmn:serviceTask id="Task_SetNew"
                      name="Durum: NEW">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setNew" />
        <zeebe:ioMapping>
          <!-- INPUT: ticketId ve priority zaten process variable olarak gelir -->
          <!-- OUTPUT: worker tarafından set edilir -->
          <zeebe:output source="=ticketId"            target="ticketId" />
          <zeebe:output source="=slaRemainingDuration" target="slaRemainingDuration" />
          <zeebe:output source="=slaWarningDuration"  target="slaWarningDuration" />
          <zeebe:output source="=candidateGroups"     target="candidateGroups" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_SetNew</bpmn:incoming>
      <bpmn:outgoing>Flow_SetNew_Assign</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ───────────────────────────────────────────────
         ATAMA GÖREVİ (User Task)
         Agent Self-Assign veya Team Leader Manuel Atama
    ─────────────────────────────────────────────────── -->
    <bpmn:intermediateCatchEvent id="Task_AssignTicket"
                                  name="Ticket Atama Bekleniyor&#10;(Agent Self-Assign /&#10;Team Leader Manuel)">
      <bpmn:incoming>Flow_SetNew_Assign</bpmn:incoming>
      <bpmn:outgoing>Flow_Assign_SetInProgress</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_TicketAssigned"
                                    messageRef="Message_TicketAssigned" />
    </bpmn:intermediateCatchEvent>

    <!-- ───────────────────────────────────────────────
         DURUM: IN_PROGRESS  +  SLA Sayacı Başlat/Devam
         Worker type: ticket.state.setInProgress
         - DB'de durumu IN_PROGRESS yap
         - slaPaused=false ise SLA sayacını devam ettir
         - slaPausedAt varsa geçen süreyi slaRemainingDuration'dan düş
         - Güncel slaRemainingDuration ve slaWarningDuration çıktısı ver
    ─────────────────────────────────────────────────── -->
    <bpmn:serviceTask id="Task_SetInProgress"
                      name="Durum: IN_PROGRESS&#10;SLA Sayacını Başlat / Devam Et">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setInProgress" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId"              target="ticketId" />
          <zeebe:input source="=slaPaused"             target="slaPaused" />
          <zeebe:input source="=slaPausedAt"           target="slaPausedAt" />
          <zeebe:input source="=slaRemainingDuration"  target="slaRemainingDuration" />
          <zeebe:input source="=slaWarningDuration"    target="slaWarningDuration" />
          <zeebe:output source="=slaRemainingDuration" target="slaRemainingDuration" />
          <zeebe:output source="=slaWarningDuration"   target="slaWarningDuration" />
          <zeebe:output source="=slaPaused"            target="slaPaused" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <!-- Birden fazla önceki adımdan gelebilir (loop) -->
      <bpmn:incoming>Flow_Assign_SetInProgress</bpmn:incoming>
      <bpmn:incoming>Flow_CustomerInfo_SetInProgress</bpmn:incoming>
      <bpmn:incoming>Flow_CustomerRejected_SetInProgress</bpmn:incoming>
      <bpmn:outgoing>Flow_SetInProgress_Work</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ───────────────────────────────────────────────
         IN_PROGRESS – ÇALIŞMA GÖREVİ (User Task)
         Agent bu görevde:
           - Internal/External yorum yazar
           - Worklog ekler
           - Aksiyon seçer: REQUEST_INFO veya SEND_SOLUTION
    ─────────────────────────────────────────────────── -->
    <bpmn:userTask id="Task_WorkOnTicket"
                   name="Ticket Üzerinde&#10;Çalışma (IN_PROGRESS)">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="=assignedAgent"
                                    candidateGroups="=assignedTeam" />
        <zeebe:userTask />
        <zeebe:ioMapping>
          <zeebe:output source="=agentAction"   target="agentAction" />
          <zeebe:output source="=solutionNote"  target="solutionNote" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SetInProgress_Work</bpmn:incoming>
      <bpmn:outgoing>Flow_Work_ActionGateway</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Boundary: Agent "Çözüm Gönder" dediğinde User Task kesilir -->
    <!-- cancelActivity="true" → SLA timer boundary'leri de otomatik iptal olur -->
    <bpmn:boundaryEvent id="Boundary_AgentSendSolution"
                        name="Agent Çözüm&#10;Gönderdi"
                        cancelActivity="true"
                        attachedToRef="Task_WorkOnTicket">
      <bpmn:outgoing>Flow_SendSolution_SetWaiting</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_AgentSendSolution" />
    </bpmn:boundaryEvent>

    <bpmn:sequenceFlow id="Flow_SendSolution_SetWaiting"
                       sourceRef="Boundary_AgentSendSolution"
                       targetRef="Task_SetWaiting" />


    <!--
      SLA UYARI SINIR OLAYI (non-interrupting)
      slaWarningDuration dolduğunda ekibe bildirim gönderilir,
      görev kesilmez. Süre, Task_SetInProgress output'undan gelir.
    -->
    <bpmn:boundaryEvent id="Boundary_SLA_Warning"
                        name="SLA Uyarısı&#10;(Süre Yaklaşıyor)"
                        cancelActivity="false"
                        attachedToRef="Task_WorkOnTicket">
      <bpmn:outgoing>Flow_SLA_Warning</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SLA_Warning">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">= if slaWarningDuration != null then slaWarningDuration else "PT20H"</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Worker type: ticket.sla.sendWarning -->
    <bpmn:serviceTask id="Task_SLA_Warning"
                      name="SLA Uyarı Bildirimi Gönder&#10;(Ekip + Lider)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.sla.sendWarning" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId"     target="ticketId" />
          <zeebe:input source="=assignedAgent" target="assignedAgent" />
          <zeebe:input source="=assignedTeam"  target="assignedTeam" />
          <zeebe:input source="=priority"      target="priority" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SLA_Warning</bpmn:incoming>
      <bpmn:outgoing>Flow_SLA_Warning_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_SLA_Warning"
                   name="SLA Uyarısı&#10;Gönderildi">
      <bpmn:incoming>Flow_SLA_Warning_End</bpmn:incoming>
    </bpmn:endEvent>

    <!--
      SLA İHLAL SINIR OLAYI (non-interrupting)
      Süre tamamen doldu → ihlal kaydedilir AMA ticket işlemi durdurmaz.
      Kural: İhlal kaydı ATANAN KİŞİYE/EKİBE yazılır.
             Sonraki devredenler sadece "tamamladı" sayılır.
    -->
    <bpmn:boundaryEvent id="Boundary_SLA_Breach"
                        name="SLA İhlali&#10;(Süre Doldu)"
                        cancelActivity="false"
                        attachedToRef="Task_WorkOnTicket">
      <bpmn:outgoing>Flow_SLA_Breach</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_SLA_Breach">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">= if slaRemainingDuration != null then slaRemainingDuration else "PT24H"</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Worker type: ticket.sla.recordBreach -->
    <bpmn:serviceTask id="Task_SLA_Breach"
                      name="SLA İhlali Kaydet&#10;(İlk Atanan Kişi/Ekibe Yaz)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.sla.recordBreach" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId"     target="ticketId" />
          <zeebe:input source="=assignedAgent" target="violatingAgent" />
          <zeebe:input source="=assignedTeam"  target="violatingTeam" />
          <zeebe:input source="=priority"      target="priority" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_SLA_Breach</bpmn:incoming>
      <bpmn:outgoing>Flow_SLA_Breach_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_SLA_Breach"
                   name="SLA İhlali&#10;Kaydedildi">
      <bpmn:incoming>Flow_SLA_Breach_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ───────────────────────────────────────────────
         AGENT AKSİYON GATEWAY
         agentAction: REQUEST_INFO | SEND_SOLUTION
    ─────────────────────────────────────────────────── -->
    <bpmn:exclusiveGateway id="Gateway_AgentAction"
                           name="Agent Aksiyonu?">
      <bpmn:incoming>Flow_Work_ActionGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Action_RequestInfo</bpmn:outgoing>
      <bpmn:outgoing>Flow_Action_SendSolution</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══════════════════════════════════════════════
         DURUM: PENDING_CUSTOMER_INPUT
         • SLA SAYACI DURDURULUR  (slaPaused = true)
         • OTO-KAPANMA KURALI UYGULANMAZ
         • Müşteri bilgi sağlayana kadar mesaj beklenir
    ═══════════════════════════════════════════════════ -->
    <bpmn:serviceTask id="Task_SetPending"
                      name="Durum: PENDING_CUSTOMER_INPUT&#10;SLA Sayacını Durdur">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setPendingCustomerInput" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId" target="ticketId" />
          <!-- Worker: slaPaused=true, slaPausedAt=now() DB'ye yaz -->
          <zeebe:output source="=slaPausedAt" target="slaPausedAt" />
          <zeebe:output source="=true"        target="slaPaused" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Action_RequestInfo</bpmn:incoming>
      <bpmn:outgoing>Flow_Pending_WaitMsg</bpmn:outgoing>
    </bpmn:serviceTask>

    <!--
      MESaj BEKLEME – Müşteri Bilgi Sağladı
      Spring Boot, müşteri portal'dan bilgi gelince Zeebe'ye
      "customerInfoProvided" mesajını ticketId ile korelatif gönderir.
      SLA SAYACI BU AŞAMADA DURDUĞUNDAN TIMER BOUNDARY YOK.
    -->
    <bpmn:intermediateCatchEvent id="Event_WaitCustomerInfo"
                                  name="Müşteri Bilgisi&#10;Bekleniyor&#10;(SLA Durduruldu)">
      <bpmn:incoming>Flow_Pending_WaitMsg</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerInfo_SetInProgress</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_CustomerInfo"
                                    messageRef="Message_CustomerInfo" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══════════════════════════════════════════════
         DURUM: WAITING_FOR_CUSTOMER
         Agent çözüm önerisini gönderdi, müşteri yanıtı bekleniyor.
         Müşteri onaylarsa → RESOLVED
         Müşteri reddederse → IN_PROGRESS (otomatik geçiş)
    ═══════════════════════════════════════════════════ -->
    <bpmn:serviceTask id="Task_SetWaiting"
                      name="Durum: WAITING_FOR_CUSTOMER&#10;Çözüm Önerisi Gönderildi">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setWaitingForCustomer" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId"    target="ticketId" />
          <zeebe:input source="=solutionNote" target="solutionNote" />
          <zeebe:output source="=slaPausedAt" target="slaPausedAt" />
          <zeebe:output source="=true"        target="slaPaused" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Action_SendSolution</bpmn:incoming>
      <bpmn:incoming>Flow_SendSolution_SetWaiting</bpmn:incoming>
      <bpmn:outgoing>Flow_Waiting_EventGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!--
      EVENT-BASED GATEWAY – Müşteri Yanıtı Bekleniyor
      İki seçenek: Onay (→ RESOLVED) veya Red (→ IN_PROGRESS)
    -->
    <bpmn:eventBasedGateway id="Gateway_CustomerDecision"
                             name="Müşteri Yanıtı&#10;Bekleniyor">
      <bpmn:incoming>Flow_Waiting_EventGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Customer_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Customer_Rejected</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <!-- Müşteri Onayladı → RESOLVED'a geç -->
    <bpmn:intermediateCatchEvent id="Event_CustomerApproved"
                                  name="Müşteri&#10;Onayladı">
      <bpmn:incoming>Flow_Customer_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved_SetResolved</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Approve"
                                    messageRef="Message_CustomerApprove" />
    </bpmn:intermediateCatchEvent>

    <!-- Müşteri Reddetti → otomatik IN_PROGRESS'e dön -->
    <bpmn:intermediateCatchEvent id="Event_CustomerRejected"
                                  name="Müşteri Reddetti&#10;(Otomatik IN_PROGRESS)">
      <bpmn:incoming>Flow_Customer_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_CustomerRejected_SetInProgress</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Reject"
                                    messageRef="Message_CustomerReject" />
    </bpmn:intermediateCatchEvent>

    <!-- ═══════════════════════════════════════════════
         DURUM: RESOLVED
         Müşteri çözümü kabul etti. 2 seçenek var:
           1. 24 saat içinde yanıt gelmezse → CLOSED (Scheduler)
           2. Müşteri açıkça onaylarsa → CLOSED (hemen)
         NOT: Müşteri RESOLVED aşamasında reddedemez.
    ═══════════════════════════════════════════════════ -->
    <bpmn:serviceTask id="Task_SetResolved"
                      name="Durum: RESOLVED">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setResolved" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId" target="ticketId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approved_SetResolved</bpmn:incoming>
      <bpmn:outgoing>Flow_Resolved_EventGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!--
      EVENT-BASED GATEWAY – RESOLVED sonrası 2 yol
      (Müşteri RESOLVED aşamasında reddedemez)
    -->
    <bpmn:eventBasedGateway id="Gateway_ResolvedDecision"
                             name="Müşteri Yanıtı /&#10;24h Timeout">
      <bpmn:incoming>Flow_Resolved_EventGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Resolved_AutoClose</bpmn:outgoing>
      <bpmn:outgoing>Flow_Resolved_ExplicitClose</bpmn:outgoing>
    </bpmn:eventBasedGateway>

    <!--
      24 SAAT OTO-KAPANMA ZAMANLAYICISI
      Müşteri 24 saat içinde herhangi bir aksiyon almazsa
      sistem otomatik olarak CLOSED'a geçer (Scheduler kuralı).
    -->
    <bpmn:intermediateCatchEvent id="Event_AutoClose24h"
                                  name="Scheduler: 24 Saatte&#10;Yanıt Gelmedi">
      <bpmn:incoming>Flow_Resolved_AutoClose</bpmn:incoming>
      <bpmn:outgoing>Flow_AutoClose_SetClosed</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_AutoClose">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <!-- Müşteri açıkça onaylayarak kapattı → hemen CLOSED -->
    <bpmn:intermediateCatchEvent id="Event_CustomerExplicitClose"
                                  name="Müşteri Onaylayarak&#10;Kapattı">
      <bpmn:incoming>Flow_Resolved_ExplicitClose</bpmn:incoming>
      <bpmn:outgoing>Flow_ExplicitClose_SetClosed</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_ExplicitClose"
                                    messageRef="Message_CustomerExplicitClose" />
    </bpmn:intermediateCatchEvent>


    <!-- ═══════════════════════════════════════════════
         DURUM: CLOSED
         Worker: SLA tamamlama süresi hesapla, DB güncelle,
                 raporlama metriklerini kaydet.
    ═══════════════════════════════════════════════════ -->
    <bpmn:serviceTask id="Task_SetClosed"
                      name="Durum: CLOSED&#10;SLA Metriklerini Kaydet">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="ticket.state.setClosed" />
        <zeebe:ioMapping>
          <zeebe:input source="=ticketId"     target="ticketId" />
          <zeebe:input source="=assignedAgent" target="assignedAgent" />
          <zeebe:input source="=assignedTeam"  target="assignedTeam" />
          <zeebe:output source="=closedAt"              target="closedAt" />
          <zeebe:output source="=totalResolutionTime"   target="totalResolutionTime" />
          <zeebe:output source="=slaComplianceStatus"   target="slaComplianceStatus" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AutoClose_SetClosed</bpmn:incoming>
      <bpmn:incoming>Flow_ExplicitClose_SetClosed</bpmn:incoming>
      <bpmn:outgoing>Flow_Closed_End</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ───────────────────────────────────────────────
         BİTİŞ
    ─────────────────────────────────────────────────── -->
    <bpmn:endEvent id="EndEvent_TicketClosed"
                   name="Ticket&#10;Kapatıldı">
      <bpmn:incoming>Flow_Closed_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ═══════════════════════════════════════════════
         SEQUENCE FLOWS
    ═══════════════════════════════════════════════════ -->

    <!-- Ana Akış -->
    <bpmn:sequenceFlow id="Flow_Start_SetNew"
                        sourceRef="StartEvent_TicketCreated"
                        targetRef="Task_SetNew" />
    <bpmn:sequenceFlow id="Flow_SetNew_Assign"
                        sourceRef="Task_SetNew"
                        targetRef="Task_AssignTicket" />
    <bpmn:sequenceFlow id="Flow_Assign_SetInProgress"
                        sourceRef="Task_AssignTicket"
                        targetRef="Task_SetInProgress" />
    <bpmn:sequenceFlow id="Flow_SetInProgress_Work"
                        sourceRef="Task_SetInProgress"
                        targetRef="Task_WorkOnTicket" />
    <bpmn:sequenceFlow id="Flow_Work_ActionGateway"
                        sourceRef="Task_WorkOnTicket"
                        targetRef="Gateway_AgentAction" />

    <!-- SLA Uyarı Sınır Akışları -->
    <bpmn:sequenceFlow id="Flow_SLA_Warning"
                        sourceRef="Boundary_SLA_Warning"
                        targetRef="Task_SLA_Warning" />
    <bpmn:sequenceFlow id="Flow_SLA_Warning_End"
                        sourceRef="Task_SLA_Warning"
                        targetRef="End_SLA_Warning" />

    <!-- SLA İhlal Sınır Akışları -->
    <bpmn:sequenceFlow id="Flow_SLA_Breach"
                        sourceRef="Boundary_SLA_Breach"
                        targetRef="Task_SLA_Breach" />
    <bpmn:sequenceFlow id="Flow_SLA_Breach_End"
                        sourceRef="Task_SLA_Breach"
                        targetRef="End_SLA_Breach" />

    <!-- Gateway → PENDING_CUSTOMER_INPUT yolu -->
    <bpmn:sequenceFlow id="Flow_Action_RequestInfo"
                        name="Ek Bilgi Talep Et"
                        sourceRef="Gateway_AgentAction"
                        targetRef="Task_SetPending">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        = agentAction = "REQUEST_INFO"
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Pending_WaitMsg"
                        sourceRef="Task_SetPending"
                        targetRef="Event_WaitCustomerInfo" />
    <!-- Müşteri bilgi sağladı → IN_PROGRESS'e dön (loop) -->
    <bpmn:sequenceFlow id="Flow_CustomerInfo_SetInProgress"
                        sourceRef="Event_WaitCustomerInfo"
                        targetRef="Task_SetInProgress" />

    <!-- Gateway → WAITING_FOR_CUSTOMER yolu -->
    <bpmn:sequenceFlow id="Flow_Action_SendSolution"
                        name="Çözüm Gönder"
                        sourceRef="Gateway_AgentAction"
                        targetRef="Task_SetWaiting">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        = agentAction = "SEND_SOLUTION"
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Waiting_EventGateway"
                        sourceRef="Task_SetWaiting"
                        targetRef="Gateway_CustomerDecision" />
    <bpmn:sequenceFlow id="Flow_Customer_Approved"
                        sourceRef="Gateway_CustomerDecision"
                        targetRef="Event_CustomerApproved" />
    <bpmn:sequenceFlow id="Flow_Customer_Rejected"
                        sourceRef="Gateway_CustomerDecision"
                        targetRef="Event_CustomerRejected" />
    <bpmn:sequenceFlow id="Flow_Approved_SetResolved"
                        sourceRef="Event_CustomerApproved"
                        targetRef="Task_SetResolved" />
    <!-- Müşteri reddetti → IN_PROGRESS'e dön (loop) -->
    <bpmn:sequenceFlow id="Flow_CustomerRejected_SetInProgress"
                        sourceRef="Event_CustomerRejected"
                        targetRef="Task_SetInProgress" />

    <!-- RESOLVED akışları -->
    <bpmn:sequenceFlow id="Flow_Resolved_EventGateway"
                        sourceRef="Task_SetResolved"
                        targetRef="Gateway_ResolvedDecision" />
    <bpmn:sequenceFlow id="Flow_Resolved_AutoClose"
                        sourceRef="Gateway_ResolvedDecision"
                        targetRef="Event_AutoClose24h" />
    <bpmn:sequenceFlow id="Flow_Resolved_ExplicitClose"
                        sourceRef="Gateway_ResolvedDecision"
                        targetRef="Event_CustomerExplicitClose" />
    <bpmn:sequenceFlow id="Flow_AutoClose_SetClosed"
                        sourceRef="Event_AutoClose24h"
                        targetRef="Task_SetClosed" />
    <bpmn:sequenceFlow id="Flow_ExplicitClose_SetClosed"
                        sourceRef="Event_CustomerExplicitClose"
                        targetRef="Task_SetClosed" />
    <!-- CLOSED → Son -->
    <bpmn:sequenceFlow id="Flow_Closed_End"
                        sourceRef="Task_SetClosed"
                        targetRef="EndEvent_TicketClosed" />

  </bpmn:process>

  <!-- =====================================================
       DİAGRAM (DI) – Camunda Modeler görsel düzeni
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_TicketManagement">

