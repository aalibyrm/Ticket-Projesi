      <!-- ─── EDGES ─── -->
      <bpmndi:BPMNEdge id="Edge_Start_SetNew" bpmnElement="Flow_Start_SetNew">
        <di:waypoint x="188" y="250" /><di:waypoint x="238" y="250" />
      </bpmndi:BPMNEdge>
